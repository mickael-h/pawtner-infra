# PostgreSQL (shared instance, two databases: keycloak_db, pawtner_db)
POSTGRES_USER=pawtner
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=postgres

# Keycloak (uses keycloak_db)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-production
KEYCLOAK_HTTP_PORT=18080
KEYCLOAK_REALM_IMPORT_FILE=pawtner-realm.dev.json
KEYCLOAK_BOOTSTRAP_FILE=pawtner-partial.dev.json
KC_DB_USERNAME=pawtner
KC_DB_PASSWORD=change-me-in-production

# Pawtner API (will use pawtner_db; set when adding API)
# DATABASE_URL=postgres://pawtner:change-me-in-production@postgres:5432/pawtner_db
# KEYCLOAK_ISSUER=http://localhost:8080/realms/pawtner
# PORT=3000
